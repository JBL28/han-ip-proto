prefix_rule(pattern=["sed", "-n", "1,220p", ".codex/skills/plan/SKILL.md"], decision="allow")
prefix_rule(pattern=["mkdir", "-p"], decision="allow")
prefix_rule(pattern=["sed", "-n", "1,240p", "DESIGN.md"], decision="allow")
prefix_rule(pattern=["find", ".", "-maxdepth", "5", "-type", "f"], decision="allow")
prefix_rule(pattern=["sed", "-n", "1,260p", "설계문서.md"], decision="allow")
prefix_rule(pattern=["wc", "-c", "설계문서.md", "wireframes/*.png"], decision="allow")
prefix_rule(pattern=["wc", "-c", "설계문서.md"], decision="allow")
prefix_rule(pattern=["sed", "-n", "1,260p", ".omx/plans/abc-page-design-plan.md"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "find mockdatas -maxdepth 3 -type f | sed 's#^#- #' | sort && printf '\\n--- sizes ---\\n' && wc -c mockdatas/* 2>/dev/null || true"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "sed -n '1,260p' mockdatas/index.md && printf '\\n--- XMLS ---\\n' && for f in mockdatas/*.xml; do echo \"--- $f\"; sed -n '1,220p' \"$f\"; done"], decision="allow")
prefix_rule(pattern=["sed", "-n", "261,620p", "mockdatas/index.md"], decision="allow")
prefix_rule(pattern=["which", "hwp5txt"], decision="allow")
prefix_rule(pattern=["find", ".", "-maxdepth", "4", "-type", "f"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "which pdftotext || which mutool || which qpdf || which python3 && pdfinfo mockdatas/한버팀_1번_소득세법_20조\\ \\(1\\).pdf 2>/dev/null | head -20 || true"], decision="allow")
prefix_rule(pattern=["/bin/bash", "-lc", "for f in mockdatas/*.pdf; do echo \"--- $f\"; strings -el \"$f\" | head -20; done"], decision="allow")
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["sed", "-n", "1,200p", "src/app.js"], decision="allow")
prefix_rule(pattern=["grep", "-n", "bottom-nav\\|nav-lucide\\|bottom-nav-icon\\|bottom-nav-link\\|header-", "-n", "src/renderers/pages.js"], decision="allow")
